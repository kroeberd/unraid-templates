<Container version="2">
<!-- 
    Mediastarr — Automated media search for Sonarr & Radarr
    Template for kroeberd/unraid-templates
    https://github.com/kroeberd/mediastarr
   -->
<Name>Mediastarr</Name>
<Repository>kroeberd/mediastarr:latest</Repository>
<Registry>https://hub.docker.com/r/kroeberd/mediastarr</Registry>
<GitHub>https://github.com/kroeberd/mediastarr</GitHub>
<Branch>main</Branch>
<Network>bridge</Network>
<Shell>sh</Shell>
<Privileged>false</Privileged>
<Support>https://github.com/kroeberd/mediastarr/issues</Support>
<Project>https://github.com/kroeberd/mediastarr</Project>
<Overview>Automated missing-content and quality-upgrade search for Sonarr and Radarr. Features: - Multiple Sonarr/Radarr instances, freely nameable (HD, 4K, Anime...) - Either service is optional — use only Sonarr, only Radarr, or any mix - SQLite search history with configurable cooldown (days) - Daily search limit - Random jitter on intervals (minimum 15 minutes enforced) - Discord webhook notifications: 6 events + periodic stats report + rate-limit protection - Sonarr search granularity: episode / season / full series - Upgrade search on/off toggle - Dark / Light / OLED themes - German and English UI and logs - First-run browser wizard — no config file editing required Independent project. Not affiliated with Huntarr.</Overview>
<Category>Downloaders: MediaApp:Other</Category>
<WebUI>http://[IP]:[PORT:7979]/</WebUI>
<TemplateURL>https://raw.githubusercontent.com/kroeberd/unraid-templates/main/templates/mediastarr.xml</TemplateURL>
<Icon>https://raw.githubusercontent.com/kroeberd/mediastarr/main/static/icon.png</Icon>
<ExtraParams>--restart unless-stopped</ExtraParams>
<PostArgs/>
<CPUset/>
<DateInstalled/>
<DonateText/>
<DonateLink/>
<Requires>At least one running Sonarr or Radarr instance reachable from this container. Recommended: same Docker network as your Arr stack.</Requires>
<!--  ── Port ────────────────────────────────────────────────  -->
<Config Name="WebUI Port" Target="7979" Default="7979" Mode="tcp" Description="Port for the Mediastarr web interface." Type="Port" Display="always" Required="true" Mask="false">7979</Config>
<!--  ── Data volume ──────────────────────────────────────────  -->
<Config Name="Data Directory" Target="/data" Default="/mnt/user/appdata/mediastarr" Mode="rw" Description="Persistent storage for config.json and the SQLite database. Without this, setup restarts on every container restart." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/mediastarr</Config>
<!--  ── Optional bootstrap (skip wizard) ────────────────────  -->
<Config Name="Sonarr API Key (optional)" Target="SONARR_API_KEY" Default="" Mode="" Description="Optional: Pre-configure Sonarr to skip the setup wizard. Find in Sonarr → Settings → General → Security → API Key. If both Sonarr and Radarr keys are set, the wizard is bypassed automatically." Type="Variable" Display="advanced" Required="false" Mask="true"/>
<Config Name="Sonarr URL (optional)" Target="SONARR_URL" Default="http://sonarr:8989" Mode="" Description="Optional: Sonarr URL. Only used when SONARR_API_KEY is also set." Type="Variable" Display="advanced" Required="false" Mask="false">http://sonarr:8989</Config>
<Config Name="Radarr API Key (optional)" Target="RADARR_API_KEY" Default="" Mode="" Description="Optional: Pre-configure Radarr to skip the setup wizard. Find in Radarr → Settings → General → Security → API Key." Type="Variable" Display="advanced" Required="false" Mask="true"/>
<Config Name="Radarr URL (optional)" Target="RADARR_URL" Default="http://radarr:7878" Mode="" Description="Optional: Radarr URL. Only used when RADARR_API_KEY is also set." Type="Variable" Display="advanced" Required="false" Mask="false">http://radarr:7878</Config>
<Config Name="Data Directory (env)" Target="DATA_DIR" Default="/data" Mode="" Description="Internal container path for data. Change only if you know what you are doing." Type="Variable" Display="advanced" Required="false" Mask="false">/data</Config>
</Container>
